{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MoFlow",
  "version": "1.3.10",
  "identifier": "app.moflow.editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' http://ipc.localhost https://ipc.localhost ws://localhost:* https://* http://*; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; font-src 'self' https://cdn.jsdelivr.net data:; img-src 'self' asset: https://asset.localhost data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "useLocalToolsDir": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis",
      "app",
      "deb",
      "appimage"
    ],
    "resources": {
      "icons/md-file.ico": "icons/md-file.ico"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "name": "Markdown",
        "description": "Markdown File",
        "ext": [
          "md"
        ],
        "mimeType": "text/markdown"
      }
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJFQjVBMThENjUwMDBCNgpSV1MyQUZEV0dGcnJBdGlUQXRxR1BOOE9vMGhzNFk1UkNrYTBEZGVqSXFLZnI5YVAxQnJGSDYxWgo=",
      "endpoints": [
        "https://github.com/xmm1989218/moflow/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      },
      "macOS": {
        "installMode": "passive"
      }
    }
  }
}
